RewriteEngine On
Options -Indexes

# Racine du site
RewriteRule ^$ public/pages/client/index.php [L]

# Pages publiques
RewriteRule ^index\.php$ public/pages/client/index.php [L]
RewriteRule ^catalogue\.php$ public/pages/client/catalogue.php [L]
RewriteRule ^panier\.php$ public/pages/client/panier.php [L]
RewriteRule ^contact\.php$ public/pages/client/contact.php [L]
RewriteRule ^foret\.php$ public/pages/client/foret.php [L]
RewriteRule ^ceremonies\.php$ public/pages/client/ceremonies.php [L]
RewriteRule ^repos_des_fideles\.php$ public/pages/client/repos_des_fideles.php [L]
RewriteRule ^recommandations\.php$ public/pages/client/recommandations.php [L]
RewriteRule ^login\.php$ public/pages/admin/login.php [L]
RewriteRule ^logout\.php$ public/pages/admin/logout.php [L]
RewriteRule ^admin\.php$ public/pages/admin/admin.php [L]
RewriteRule ^gestion\.php$ public/pages/admin/gestion.php [L]
RewriteRule ^modifier\.php$ public/pages/admin/modifier.php [L]
RewriteRule ^supprimer\.php$ public/pages/admin/supprimer.php [L]
RewriteRule ^payment-form\.php$ public/pages/payment/payment-form.php [L]
RewriteRule ^payment-success\.php$ public/pages/payment/payment-success.php [L]
RewriteRule ^mentions-legales\.php$ public/pages/info/mentions-legales.php [L]

# Endpoints techniques
RewriteRule ^ajouter_panier\.php$ public/endpoints/ajouter_panier.php [L]
RewriteRule ^create-checkout-session\.php$ public/endpoints/create-checkout-session.php [L]
RewriteRule ^process-payment\.php$ public/endpoints/process-payment.php [L]
RewriteRule ^traitement_jardin\.php$ public/endpoints/traitement_jardin.php [L]
RewriteRule ^traitement_paiement\.php$ public/endpoints/traitement_paiement.php [L]
RewriteRule ^update_stock\.php$ public/endpoints/update_stock.php [L]

# Ressources publiques
RewriteRule ^style\.css$ public/style.css [L]
RewriteRule ^script\.js$ public/script.js [L]
RewriteRule ^images/(.*)$ public/images/$1 [L]
